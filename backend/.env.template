# backend/.env.template
# ─────────────────────────────────────────────────────────────────────────────
# Template for LOCAL DEVELOPMENT.
#
# Usage:
#   cp backend/.env.template .env          ← root .env (used by docker-compose.yml)
#   cp backend/.env.template backend/.env  ← backend/.env (used by host Node dev)
#
# For production: copy .env.prod.example → .env.prod
# ─────────────────────────────────────────────────────────────────────────────

# --- CORS -------------------------------------------------------------------
# Storefront on 8000, admin/API on 9000
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:9000,http://localhost:8000,https://docs.medusajs.com

# --- Redis ------------------------------------------------------------------
# Docker maps container 6379 → host 6380 (see docker-compose.yml)
REDIS_URL=redis://localhost:6380

# --- Auth secrets -----------------------------------------------------------
# Dev-only placeholders — NEVER use these values in production
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# --- PostgreSQL -------------------------------------------------------------
# Docker maps container 5432 → host 5433 (see docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/medusa-store
DB_NAME=medusa-store

# --- Admin / Storefront URLs ------------------------------------------------
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_STOREFRONT_URL=http://localhost:8000

# --- Stripe Payment Provider ------------------------------------------------
# Leave empty to use manual payment in local dev
# Backend secret key from https://dashboard.stripe.com/apikeys (sk_test_...)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- SMTP / Email Notifications ---------------------------------------------
# Leave empty to disable email (subscribers will be registered but silently skipped)
# Works with any SMTP: Gmail (port 587), Mailgun, SES, self-hosted Postfix, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
# Set to "true" for port 465 (SMTPS), "false" for STARTTLS (port 587)
SMTP_SECURE=true