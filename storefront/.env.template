# storefront/.env.template
# ─────────────────────────────────────────────────────────────────────────────
# Template for LOCAL DEVELOPMENT.
#
# Usage:
#   cp storefront/.env.template storefront/.env.local
#
# For production: copy .env.prod.example → .env.prod
# ─────────────────────────────────────────────────────────────────────────────

# --- Medusa Backend ---------------------------------------------------------
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# --- Publishable API Keys ---------------------------------------------------
# Obtain from Admin after first boot: Settings → Publishable API Keys
# The B2C/B2B keys are generated by: yarn seed:silk
# Use the same key for all three if you only have one sales channel.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_B2C_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_B2B_PUBLISHABLE_KEY=

# --- URLs -------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# --- Region -----------------------------------------------------------------
# Default region (ISO-2 lowercase) used when Vercel country header is absent
NEXT_PUBLIC_DEFAULT_REGION=us

# --- Revalidation -----------------------------------------------------------
# Secret for Next.js on-demand ISR — dev placeholder is fine locally
REVALIDATE_SECRET=supersecret

# --- Stripe -----------------------------------------------------------------
# Public key from https://dashboard.stripe.com/apikeys (pk_test_...)
# Leave empty to use manual payment in local dev
NEXT_PUBLIC_STRIPE_KEY=
